<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLogin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:minHeight="72dp"
        android:paddingTop="20dp"
        app:navigationIcon="@drawable/ic_back_sized"
        app:navigationIconTint="@color/c_topbar_icon"
        app:titleCentered="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_title"
                android:textColor="@color/c_topbar_title"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/c_bg"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="28dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/identify_title"
                android:textColor="@color/c_title"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:text="Ravi de vous revoir !"
                android:textColor="@color/c_subtext"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="emailAddress"
                android:backgroundTint="@color/c_field_underline"
                android:drawableStart="@drawable/ic_mail_sized"
                android:drawablePadding="14dp"
                android:drawableTint="@color/c_field_icon"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="@color/c_text"
                android:textColorHint="@color/c_hint" />

            <View
                android:layout_width="match_parent"
                android:layout_height="18dp" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="password"
                android:backgroundTint="@color/c_field_underline"
                android:drawableStart="@drawable/ic_lock_sized"
                android:drawablePadding="14dp"
                android:drawableTint="@color/c_field_icon"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="@color/c_text"
                android:textColorHint="@color/c_hint" />

            <TextView
                android:id="@+id/tvForgot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="end"
                android:text="@string/forgot_password"
                android:textAllCaps="true"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="22dp"
                android:backgroundTint="@color/primary"
                android:letterSpacing="0.03"
                android:onClick="login"
                android:text="@string/btn_login_caps"
                android:textColor="@color/c_btn_primary_text"
                android:textStyle="bold"
                app:cornerRadius="50dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_user"
                    android:textColor="@color/c_subtext"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvCreateAccount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/create_account"
                    android:textAllCaps="true"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- OU avec traits -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/c_divider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:text="@string/or"
                    android:textAllCaps="true"
                    android:textColor="@color/c_hint"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/c_divider" />
            </LinearLayout>

            <!-- Facebook -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFacebook"
                android:layout_width="wrap_content"
                android:layout_height="54dp"
                android:layout_gravity="center"
                android:layout_marginTop="18dp"
                android:background="@android:color/transparent"
                android:drawableStart="@drawable/ic_facebook_sized"
                android:drawablePadding="12dp"
                android:elevation="0dp"
                android:outlineProvider="none"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:stateListAnimator="@null"
                android:text="@string/facebook_continue"
                android:textAllCaps="false"
                android:textColor="@color/c_btn_fb_text"
                android:textStyle="bold"
                app:drawableTint="@color/c_btn_fb_icon" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
