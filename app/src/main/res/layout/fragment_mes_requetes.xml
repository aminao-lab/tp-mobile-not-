<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F0F0F0">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp">

        <!-- Solde éco-coins -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card_habitat" android:padding="14dp"
            android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Mon solde"
                android:textColor="#4CAF50" android:textStyle="bold" android:textSize="13sp"/>
            <TextView android:id="@+id/tvEcoCoins" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="💰 0 éco-coins"
                android:textColor="#222222" android:textStyle="bold" android:textSize="14sp"/>
        </LinearLayout>

        <!-- Calendrier -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card_habitat"
            android:padding="14dp" android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <Button android:id="@+id/btnPrev" android:layout_width="wrap_content"
                    android:layout_height="36dp" android:text="‹" android:textSize="18sp"
                    android:backgroundTint="#E0E0E0" android:textColor="#333333"/>
                <TextView android:id="@+id/tvMonth" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:text="Mars 2026"
                    android:textSize="14sp" android:textStyle="bold" android:textColor="#222222"/>
                <Button android:id="@+id/btnNext" android:layout_width="wrap_content"
                    android:layout_height="36dp" android:text="›" android:textSize="18sp"
                    android:backgroundTint="#E0E0E0" android:textColor="#333333"/>
            </LinearLayout>

            <GridLayout android:id="@+id/calendarGrid" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:columnCount="7"
                android:useDefaultMargins="false"/>
        </LinearLayout>

        <!-- Légende -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginBottom="8dp" android:background="@drawable/bg_card_habitat"
            android:padding="10dp">
            <View android:layout_width="14dp" android:layout_height="14dp"
                android:background="#C0DD97" android:layout_marginRight="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Libre (0–30%)" android:textSize="11sp" android:textColor="#666666"
                android:layout_marginRight="10dp"/>
            <View android:layout_width="14dp" android:layout_height="14dp"
                android:background="#FAC775" android:layout_marginRight="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Chargé (30–70%)" android:textSize="11sp" android:textColor="#666666"
                android:layout_marginRight="10dp"/>
            <View android:layout_width="14dp" android:layout_height="14dp"
                android:background="#F7C1C1" android:layout_marginRight="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Saturé (+70%)" android:textSize="11sp" android:textColor="#666666"/>
        </LinearLayout>

        <!-- Explication -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card_habitat" android:padding="12dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="💡 Appuyez sur un jour pour voir les créneaux. Choisissez un créneau vert plutôt qu'un créneau rouge pour gagner des éco-coins ! Le symbole • indique un engagement existant."
                android:textSize="11sp" android:textColor="#888888" android:lineSpacingExtra="2dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
