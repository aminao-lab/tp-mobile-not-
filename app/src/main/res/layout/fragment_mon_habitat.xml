<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/c_bg">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Card infos habitat -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_habitat"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/nav_mon_habitat"
                    android:textSize="13sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"/>
                <Button
                    android:id="@+id/btn_edit_habitat"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/edit_habitat"
                    android:textSize="11sp"
                    android:backgroundTint="@color/primary_surface"
                    android:textColor="@color/primary"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/resident"
                    android:textColor="@color/c_subtext"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/tv_resident"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="…"
                    android:textColor="@color/c_text"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/floor_label"
                    android:textColor="@color/c_subtext"
                    android:textSize="13sp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_etage_border"
                    android:paddingLeft="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:paddingRight="0dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ETAGE"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/c_subtext"
                        android:layout_marginRight="4dp"/>
                    <TextView
                        android:id="@+id/tv_floor"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="@drawable/bg_etage_number"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:text="…"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/area_label"
                    android:textColor="@color/c_subtext"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/tv_area"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="… m²"
                    android:textColor="@color/c_text"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Card équipements -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_habitat"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/equipments"
                    android:textSize="13sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tv_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="…"
                    android:textSize="12sp"
                    android:textColor="@color/c_subtext"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_appliances"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <Button
                android:id="@+id/btn_add_appliance"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="@string/add_appliance"
                android:backgroundTint="@color/primary"
                android:textColor="@color/c_btn_primary_text"
                android:layout_marginTop="8dp"
                app:cornerRadius="50dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/c_divider"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/total_consumption"
                    android:textColor="@color/c_subtext"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tv_total_watt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="… W"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
