<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp">
    <EditText android:id="@+id/etApplianceName" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Nom (ex: Lave-linge)"
        android:layout_marginBottom="12dp"/>
    <EditText android:id="@+id/etApplianceRef" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Référence (ex: MLV-001)"
        android:layout_marginBottom="12dp"/>
    <EditText android:id="@+id/etApplianceWattage" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Puissance en Watts (ex: 2000)"
        android:inputType="number"/>
</LinearLayout>
