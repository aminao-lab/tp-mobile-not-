<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/c_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarForgot"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Mot de passe oublié"
        app:titleTextColor="@color/c_topbar_title"
        app:navigationIconTint="@color/c_topbar_icon"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Entrez votre adresse email pour recevoir un lien de réinitialisation."
            android:textColor="@color/c_subtext"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/etForgotEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Adresse email"
            android:inputType="textEmailAddress"
            android:padding="12dp"
            android:backgroundTint="@color/c_field_underline"
            android:textColor="@color/c_text"
            android:textColorHint="@color/c_hint"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnSendReset"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Envoyer le lien"
            android:backgroundTint="@color/primary"
            android:textColor="@color/c_btn_primary_text"
            app:cornerRadius="50dp"/>
    </LinearLayout>
</LinearLayout>
